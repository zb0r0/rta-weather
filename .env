# ── Lokalizacja (używana przez producenta i historical-fetch) ─
OWM_LAT=52.25
OWM_LON=21.0

# ── Dane na żywo (Open-Meteo current, aktualizacja co ~15 min) ─
# 900 = 15 minut — odpytywanie częściej nie przynosi nowych danych
FETCH_INTERVAL_SECONDS=900

# ── Dane historyczne (Open-Meteo archive, darmowe, bez klucza) ─
# Zmień HISTORY_START_DATE żeby pobrać szerszy zakres dla ML
# Np. "2020-01-01" da 5+ lat danych godzinowych (~47 000 rekordów)
HISTORY_START_DATE=2020-01-01
HISTORY_END_DATE=2026-06-10

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=weather
POSTGRES_USER=weather_user
POSTGRES_PASSWORD=weather_pass

# ── pgAdmin ───────────────────────────────────────────────────
PGADMIN_EMAIL=admin@sgh.waw.pl
PGADMIN_PASSWORD=admin

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
